generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  plan          Plan      @default(FREE)
  
  // Gamificación
  points        Int       @default(0)
  pushToken     String?
  
  createdAt     DateTime  @default(now())

  partnerProfile     PartnerProfile?
  personalityProfile PersonalityProfile?
  aiInteractions     AIInteraction[]
  notifications      Notification[]
  missions           Mission[]
  emotionalRecords   EmotionalRecord[]
}

enum Plan {
  FREE
  PREMIUM
}

model PartnerProfile {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])

  // Datos del ciclo
  cycleLength      Int       
  periodDuration   Int       
  lastPeriodDate   DateTime
  isIrregular      Boolean   @default(false)
  irregularRange   Int?      

  // Perfil de personalidad base
  personalityType  PersonalityType
  socialLevel      SocialLevel
  privacyLevel     PrivacyLevel
  conflictStyle    ConflictStyle
  affectionStyle   AffectionStyle

  // Control de misiones
  lastMissionReset DateTime?

  // MBTI Link
  personalityProfileId String?

  cycleLogs        CycleLog[]
  updatedAt        DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// MBTI y perfil de personalidad enriquecido
// ─────────────────────────────────────────────

model PersonalityProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  // Tipo MBTI calculado (ej: "INFJ")
  mbtiType        String?

  // Confianza por dimensión (0.0 a 1.0)
  mbtiConfidence  Json     @default("{}")

  // Estilo de apego
  attachmentStyle AttachmentStyle @default(SECURE)

  // Preferencias enriquecidas del quiz
  preferences     Json     @default("{}")

  // Dimensiones ya exploradas
  exploredDims    String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Cache de insights generados por IA
model PersonalityInsight {
  id          String   @id @default(uuid())

  // Clave única: "INFJ_LUTEAL_dia_dificil_VERBAL_AVOIDANT"
  cacheKey    String   @unique
  insight     String
  hitCount    Int      @default(0)

  createdAt   DateTime @default(now())
  expiresAt   DateTime
}

enum AttachmentStyle {
  ANXIOUS    
  SECURE     
  AVOIDANT   
}

enum InsightContext {
  plan_romantico
  conflicto_tension
  necesita_espacio
  sorpresa_detalle
  comunicacion_importante
  dia_dificil
  plan_tactic_diario
}

enum PersonalityType {
  INTROVERTED
  EXTROVERTED
  AMBIVERT
}

enum SocialLevel {
  LOW     
  MEDIUM
  HIGH    
}

enum PrivacyLevel {
  VERY_PRIVATE
  MODERATE
  OPEN
}

enum ConflictStyle {
  AVOIDANT    
  DIRECT      
  PASSIVE     
}

enum AffectionStyle {
  PHYSICAL    
  VERBAL      
  ACTS        
  QUALITY     
}

model CycleLog {
  id             String    @id @default(uuid())
  profileId      String
  profile        PartnerProfile @relation(fields: [profileId], references: [id])
  logDate        DateTime
  phase          CyclePhase
  dayOfCycle     Int
  notes          String?
}

enum CyclePhase {
  MENSTRUAL     
  FOLLICULAR    
  OVULATION     
  LUTEAL        
}

model AIInteraction {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  userInput     String?   
  aiResponse    String
  phaseContext  CyclePhase
  promptTokens  Int
  createdAt     DateTime  @default(now())
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  message       String
  type          NotifType
  scheduledAt   DateTime
  sentAt        DateTime?
  opened        Boolean   @default(false)
}

enum NotifType {
  PHASE_CHANGE    
  DAILY_TIP       
  PERIOD_SOON     
  CUSTOM          
}

model Mission {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  description   String?
  progress      Int       @default(0) 
  isCompleted   Boolean   @default(false)
  phaseContext  CyclePhase
  category      String?   
  
  // Gamificación y Evidencia
  imageUrl      String?   
  pointsAwarded Int       @default(0)
  completedAt   DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmotionalRecord {
  id                String     @id @default(uuid())
  userId            String
  user              User       @relation(fields: [userId], references: [id])

  // Datos del análisis
  dominantEmotion   String
  confidence        Float      @default(0)
  isAuthentic       Boolean?   // null = no determinable
  isSuppressed      Boolean    @default(false)
  hasDiscrepancy    Boolean    @default(false)
  authenticityLabel String
  rawEmotions       Json       @default("{}")

  // Contexto en el momento del análisis
  phase             CyclePhase
  environment       String
  analysisReliable  Boolean    @default(true)

  createdAt         DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([userId, dominantEmotion])
}

